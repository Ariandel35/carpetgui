{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Vanilla-based Carpet rule GUI - no external UI dependencies",
  "authors": ["Ariandel"],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["Ariandel.carpetgui.CarpetGUIRewrite"],
    "client": ["Ariandel.carpetgui.CarpetGUIRewriteClient"],
    "carpet": ["Ariandel.carpetgui.CarpetGUIRewrite"]
  },
  "mixins": [
    "carpetgui-rewrite.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": "${minecraft_dep}",
    "carpet": "*"
  }
}
